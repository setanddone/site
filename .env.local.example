# =============================================================
# Set & Done — Environment Variables
# Copy this file to `.env.local` (never committed) and fill in values.
# In Vercel, set these under Project → Settings → Environment Variables.
# =============================================================

# Resend API key — used by /api/inquiry (inquiry notification +
# auto-response) and /api/subscribe (Field Notes signups).
# Without it, both routes return 503 and the forms show their
# "email us directly" fallback. Get one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Optional — overrides for email routing. The RESEND_FROM domain must be
# verified in Resend before sends will succeed.
# RESEND_FROM="Set & Done <noreply@setanddone.co>"
# INQUIRY_TO=kimberly@setanddone.co

# Optional — Field Notes subscriber audience. When set, /api/subscribe
# adds contacts to this Resend audience; otherwise it emails INQUIRY_TO
# so no signup is lost. Create one at https://resend.com/audiences
# RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Canonical site URL. Used by next/metadata for OG tags, canonical
# links, sitemap, and the LocalBusiness JSON-LD.
# Primary domain TBD between the two registered:
#   - https://setanddone.co        (default in code)
#   - https://setanddoneevents.com
NEXT_PUBLIC_SITE_URL=https://setanddone.co
