# =============================================================
# Set & Done — Environment Variables
# Copy this file to `.env.local` (never committed) and fill in values.
# In Vercel, set these under Project → Settings → Environment Variables.
# =============================================================

# Resend API key — used by /api/inquiry to send the notification
# email to Kimberly and the auto-response to the inquirer.
# Get one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Canonical site URL. Used by next/metadata for OG tags, canonical
# links, sitemap, and the LocalBusiness JSON-LD.
# Primary domain TBD between the two registered:
#   - https://setanddone.co        (default in code)
#   - https://setanddoneevents.com
NEXT_PUBLIC_SITE_URL=https://setanddone.co
